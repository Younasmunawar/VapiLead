PORT=3000
NODE_ENV=development

# MongoDB Atlas
MONGO_URI=mongodb+srv://USERNAME:PASSWORD@CLUSTER.mongodb.net/kenny_vapi?retryWrites=true&w=majority

# Vapi browser call
VAPI_PUBLIC_KEY=your_vapi_public_key
VAPI_ASSISTANT_ID=your_kenny_assistant_id

# Brevo HTTPS transactional email API (works on Render Free)
BREVO_API_KEY=your_brevo_api_key
EMAIL_FROM=your_verified_sender@example.com
EMAIL_FROM_NAME=Kenny Voice Agent
EMAIL_TO=notification_receiver@example.com
